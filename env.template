# Copy this file to .env and fill in your values:
#   cp env.template .env
#
# Also copy example config files:
#   cp config/companies.example.json config/companies.json
#   cp resume/master_resume.example.txt resume/master_resume.txt

# --- Profile (job search preferences) ---
USER_NAME=Your Name
TARGET_ROLES=Senior Software Engineer,Software Engineer,Full Stack Developer
JOB_LOCATION=India
FILTER_BY_ROLE=true
MIN_MATCH_SCORE=65
JOB_LOOKBACK=r604800

# Path to your company shortlist (copy from config/companies.example.json)
COMPANIES_CONFIG_PATH=config/companies.json

# Path to your master resume (for optional --with-ai mode)
RESUME_PATH=resume/master_resume.txt

# --- API keys ---
CLAUDE_API_KEY=

# --- Fetch settings ---
CHECK_INTERVAL_MINUTES=5
FETCH_CONCURRENCY=8

# --- Experience filter ---
# Jobs requiring between EXPERIENCE_MIN and EXPERIENCE_MAX years are kept
EXPERIENCE_YEARS=4
EXPERIENCE_MIN=2
EXPERIENCE_MAX=6
FILTER_BY_EXPERIENCE=true

# --- Email alerts (required for notifications) ---
# Recipient address — where job alerts are sent
NOTIFY_EMAIL=your_personal_email@gmail.com

# Option 1: Gmail (recommended — easiest)
# 1. Enable 2FA on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (no spaces)
GMAIL_APP_PASSWORD=
# Optional: defaults to NOTIFY_EMAIL if unset
# GMAIL_USER=your_personal_email@gmail.com

# Option 2: Maileroo API (Sending Key from Maileroo dashboard)
# MAILEROO_API_KEY=your_sending_key
# SMTP_FROM=your_address@your-domain.maileroo.org

# Option 3: Maileroo SMTP (or any SMTP provider)
# SMTP_HOST=smtp.maileroo.com
# SMTP_PORT=587
# SMTP_USER=your_address@your-domain.maileroo.org
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=your_address@your-domain.maileroo.org
# SMTP_FROM_NAME=Job Agent
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# Alternative: comma-separated companies in .env instead of companies.json
# TARGET_COMPANIES=Google,Microsoft,Amazon

# =============================================================================
# GitHub Actions (repo → Settings → Secrets and variables → Actions)
# =============================================================================
# Use a PRIVATE repo so job data and secrets stay private.
#
# Required for email alerts:
#   NOTIFY_EMAIL          your inbox
#   GMAIL_APP_PASSWORD    Gmail app password (recommended)
#
# Job search (recommended):
#   TARGET_COMPANIES      Google,Microsoft,Amazon,Meta
#   TARGET_ROLES          Software Engineer,Senior Software Engineer
#   JOB_LOCATION          India
#   USER_NAME             Your Name
#
# Optional private files (multiline secrets — not in the repo):
#   COMPANIES_JSON        full contents of config/companies.json
#   MASTER_RESUME         full resume text (only needed for --with-ai)
#
# Alternative email (instead of GMAIL_APP_PASSWORD):
#   MAILEROO_API_KEY      or SMTP_HOST + SMTP_USER + SMTP_PASSWORD + SMTP_FROM
#
# Test: Actions → Job Agent → Run workflow → check "Send a test email only"
